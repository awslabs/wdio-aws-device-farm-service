{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "types",
    "emitDeclarationOnly": true,
    "resolveJsonModule": true,
    "removeComments": true,
    "strictFunctionTypes": false,
    "lib": [
      "dom",
      "ES2021"
    ],
    "outDir": "dist/",
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "src/"
  ]
}
